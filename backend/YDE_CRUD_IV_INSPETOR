CLASS lsc_yde_crud_iv_inspetor DEFINITION INHERITING FROM cl_abap_behavior_saver.

  PROTECTED SECTION.

    METHODS save_modified REDEFINITION.

ENDCLASS.

CLASS lsc_yde_crud_iv_inspetor IMPLEMENTATION.

  METHOD save_modified.


    " 1. Verifica se houve alguma alteraçăo (Update) vinda do Front-end no Inspetor
    IF update-yde_crud_iv_inspetor IS NOT INITIAL.

      LOOP AT update-yde_crud_iv_inspetor INTO DATA(ls_inspetor).

        " 2. Busca o CPF real no banco usando o Id técnico que está sendo editado
        SELECT SINGLE cpf
          FROM ysinspetor
         WHERE id_inspetor = @ls_inspetor-idinspetor
          INTO @DATA(lv_cpf).

        " 3. Se o nome do inspetor foi alterado, atualiza em cascata na Atribuiçăo
        IF ls_inspetor-nome IS NOT INITIAL AND lv_cpf IS NOT INITIAL.
          UPDATE ysatribuicao
             SET nome = @ls_inspetor-nome
           WHERE cpf  = @lv_cpf
           AND ativo = @abap_true.
        ENDIF.

      ENDLOOP.
    ENDIF.

  ENDMETHOD.

ENDCLASS.

CLASS lhc_yde_crud_iv_inspetor DEFINITION INHERITING FROM cl_abap_behavior_handler.
  PRIVATE SECTION.

    METHODS get_instance_authorizations FOR INSTANCE AUTHORIZATION
      IMPORTING keys REQUEST requested_authorizations FOR yde_crud_iv_inspetor RESULT result.

    METHODS deletarregistro FOR MODIFY
      IMPORTING keys FOR ACTION yde_crud_iv_inspetor~deletarregistro RESULT result.

    METHODS setativodefault FOR DETERMINE ON MODIFY
      IMPORTING keys FOR yde_crud_iv_inspetor~setativodefault.

    METHODS earlynumbering_create FOR NUMBERING
      IMPORTING entities FOR CREATE yde_crud_iv_inspetor.

    METHODS validarcpf FOR VALIDATE ON SAVE
      IMPORTING keys FOR yde_crud_iv_inspetor~validarcpf.

ENDCLASS.

CLASS lhc_yde_crud_iv_inspetor IMPLEMENTATION.

  METHOD get_instance_authorizations.
  ENDMETHOD.

  METHOD deletarregistro.

    DATA(lv_hoje) = sy-datum.
    GET TIME STAMP FIELD DATA(lv_timestamp_modificacao).

    LOOP AT keys INTO DATA(ls_key).

      " 1. Busca o CPF do inspetor antes de alterar o status
      SELECT SINGLE cpf FROM ysinspetor
       WHERE id_inspetor = @ls_key-idinspetor
        INTO @DATA(lv_cpf).

      " 2. SOFT DELETE DO INSPETOR
      " Adicionado o preenchimento da Hora de Modificacăo técnica (timestamp)
      UPDATE ysinspetor
         SET ativo            = @abap_false,
             data_fim         = @lv_hoje,
             muda_em = @lv_timestamp_modificacao
       WHERE id_inspetor = @ls_key-idinspetor.

      " 3. CASCADE: Desativa e atualiza os tempos nas atribuiçőes vinculadas
      IF sy-subrc = 0 AND lv_cpf IS NOT INITIAL.
        UPDATE ysatribuicao
           SET ativo            = @abap_false,
               data_fim         = @lv_hoje,
               muda_em = @lv_timestamp_modificacao
         WHERE cpf      = @lv_cpf
         AND ativo    = @abap_true. " Garante que mexe apenas na linha que estava ativa
      ENDIF.

      APPEND VALUE #( idinspetor = ls_key-idinspetor
                      %param      = CORRESPONDING #( ls_key ) ) TO result.
    ENDLOOP.

  ENDMETHOD.

  METHOD setativodefault.

    " 1. Lę os registros atuais em processamento
    READ ENTITIES OF yde_crud_iv_inspetor IN LOCAL MODE
      ENTITY yde_crud_iv_inspetor
        FIELDS ( ativo datainicio criadoem ) WITH CORRESPONDING #( keys )
      RESULT DATA(lt_inspetores).

    DATA lt_update TYPE TABLE FOR UPDATE yde_crud_iv_inspetor.

    " Captura a data e o carimbo de data/hora atual do servidor
    DATA(lv_data_atual) = sy-datum.
    GET TIME STAMP FIELD DATA(lv_timestamp_atual).

    " 2. Preenche os valores padrőes iniciais se estiverem vazios
    LOOP AT lt_inspetores INTO DATA(ls_inspetor) .

      " Se o ativo OU a data de início estiverem vazios, nós preenchemos para blindar contra cache
      IF ls_inspetor-ativo IS INITIAL OR ls_inspetor-datainicio IS INITIAL.

        APPEND VALUE #(
          %tky         = ls_inspetor-%tky
          ativo        = COND #( WHEN ls_inspetor-ativo IS INITIAL THEN abap_true ELSE ls_inspetor-ativo )
          datainicio   = COND #( WHEN ls_inspetor-datainicio IS INITIAL THEN lv_data_atual ELSE ls_inspetor-datainicio )
          criadoem  = COND #( WHEN ls_inspetor-criadoem IS INITIAL THEN lv_timestamp_atual ELSE ls_inspetor-criadoem )
        ) TO lt_update.

      ENDIF.
    ENDLOOP.

    IF lt_update IS NOT INITIAL.
      MODIFY ENTITIES OF yde_crud_iv_inspetor IN LOCAL MODE
        ENTITY yde_crud_iv_inspetor
          UPDATE FIELDS ( ativo datainicio criadoem ) WITH lt_update
        REPORTED DATA(lt_reported).
    ENDIF.
  ENDMETHOD.

  METHOD earlynumbering_create.

    DATA: lv_next_number TYPE char10.

    LOOP AT entities INTO DATA(ls_entity) USING KEY id WHERE idinspetor IS INITIAL.
      CALL FUNCTION 'NUMBER_GET_NEXT'
        EXPORTING
          nr_range_nr = '01'
          object      = 'YSNUM_INS'
        IMPORTING
          number      = lv_next_number
        EXCEPTIONS
          OTHERS      = 7.

      IF sy-subrc = 0.
        CALL FUNCTION 'CONVERSION_EXIT_ALPHA_INPUT'
          EXPORTING
            input  = lv_next_number
          IMPORTING
            output = lv_next_number.

        APPEND VALUE #( %cid       = ls_entity-%cid
                        idinspetor = lv_next_number ) TO mapped-yde_crud_iv_inspetor.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.


  METHOD validarcpf.

    READ ENTITIES OF yde_crud_iv_inspetor IN LOCAL MODE
      ENTITY yde_crud_iv_inspetor
        FIELDS ( cpf ) WITH CORRESPONDING #( keys )
      RESULT DATA(lt_inspetores).

    LOOP AT lt_inspetores INTO DATA(ls_inspetor).
      DATA(lv_valido) = abap_false.

      " Limpa caracteres residuais caso venham do front
      DATA(lv_cpf_limpo) = ls_inspetor-cpf.
      REPLACE ALL OCCURRENCES OF '.' IN lv_cpf_limpo WITH ''.
      REPLACE ALL OCCURRENCES OF '-' IN lv_cpf_limpo WITH ''.
      CONDENSE lv_cpf_limpo NO-GAPS.

      " Chama a Function corrigida e ativa
      CALL FUNCTION 'YSFM_VALIDA_CPF'
        EXPORTING
          i_cpf    = lv_cpf_limpo
        IMPORTING
          e_valido = lv_valido.

      IF lv_valido = abap_false.
        APPEND VALUE #( %tky = ls_inspetor-%tky ) TO failed-yde_crud_iv_inspetor.

        APPEND VALUE #(
            %tky = ls_inspetor-%tky
            %element-cpf = if_abap_behv=>mk-on
            %msg = new_message_with_text(
                     severity = if_abap_behv_message=>severity-error
                     text     = 'O número de CPF informado é inválido'
                   )
        ) TO reported-yde_crud_iv_inspetor.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.

ENDCLASS.
