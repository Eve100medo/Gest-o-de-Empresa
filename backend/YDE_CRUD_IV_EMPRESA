CLASS lsc_yde_crud_iv_empresa DEFINITION INHERITING FROM cl_abap_behavior_saver.

  PROTECTED SECTION.

    METHODS save_modified REDEFINITION.

ENDCLASS.

CLASS lsc_yde_crud_iv_empresa IMPLEMENTATION.

  METHOD save_modified.

     " 1. Verifica se houve alguma alteraçăo (Update) vinda do Front-end
    IF update-yde_crud_iv_empresa IS NOT INITIAL.

      LOOP AT update-yde_crud_iv_empresa INTO DATA(ls_empresa).

        " 2. Busca o CNPJ real no banco usando o Id técnico que está sendo editado
        SELECT SINGLE cnpj
          FROM ysempresa
         WHERE id_empresa = @ls_empresa-idempresa
          INTO @DATA(lv_cnpj).

        " 3. Se a descriçăo/nome da empresa foi alterada, atualiza em cascata na Atribuiçăo
        IF ls_empresa-empresa IS NOT INITIAL AND lv_cnpj IS NOT INITIAL.
          UPDATE ysatribuicao
             SET empresa = @ls_empresa-empresa
           WHERE cnpj    = @lv_cnpj
           AND ativo   = @abap_true.
        ENDIF.

      ENDLOOP.
    ENDIF.

  ENDMETHOD.

ENDCLASS.

